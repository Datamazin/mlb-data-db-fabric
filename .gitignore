# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/

# uv — commit uv.lock and .python-version; never commit .venv
# uv.lock  ← intentionally NOT ignored (reproducible installs)
# .python-version ← intentionally NOT ignored (pins interpreter)

# data/ is local only — never commit raw data
data/

# Parquet / Arrow
*.parquet
*.arrow

# Environment
.env
.env.*

# Streamlit secrets (never commit — paste into Streamlit Cloud dashboard instead)
.streamlit/secrets.toml

# Azure credentials
*.pem
*.key
azureauth.json

# Test / coverage
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# Type checking
.mypy_cache/

# Ruff
.ruff_cache/

# IDE
.vscode/settings.json
.idea/
*.swp
*.swo

# Claude Code — machine-local config, not shared
.claude/

# macOS
.DS_Store
