# Copy to .env and fill in values. Never commit .env.

# ── Fabric Warehouse ─────────────────────────────────────────────────────────
# Either set FABRIC_CONNECTION_STRING directly, or set the three parts below.
FABRIC_CONNECTION_STRING=
# Parts (used when FABRIC_CONNECTION_STRING is empty):
FABRIC_SERVER=<workspace_id>.datawarehouse.fabric.microsoft.com
FABRIC_DATABASE=<warehouse_name>
# Authentication: ActiveDirectoryMsi (Managed Identity, default in Fabric notebooks)
# or ActiveDirectoryServicePrincipal (CI / local dev with a service principal)
FABRIC_AUTH=ActiveDirectoryMsi
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=

# ── OneLake (ADLS Gen2 endpoint for bronze Parquet) ──────────────────────────
ONELAKE_WORKSPACE_ID=<workspace_guid>
ONELAKE_LAKEHOUSE_NAME=mlb_bronze
# Derived bronze root: {ONELAKE_WORKSPACE_ID}/{ONELAKE_LAKEHOUSE_NAME}.Lakehouse/Files/bronze

# ── Pipeline settings ────────────────────────────────────────────────────────
MLB_API_BASE_URL=https://statsapi.mlb.com/api
MLB_API_RATE_LIMIT_RPS=8
MLB_API_MAX_RETRIES=5

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
